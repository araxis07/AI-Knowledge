{
  "name": "ai-knowledge-base",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "test:e2e": "playwright test",
    "test:e2e:core": "playwright test --grep-invert @provider",
    "test:e2e:provider": "playwright test --grep @provider",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "next": "16.2.2",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "24.6.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3"
  }
}
